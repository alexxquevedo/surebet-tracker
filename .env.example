# ─────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL
# ─────────────────────────────────────────────
# Via PgBouncer (para aplicación serverless)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL (solo para migraciones Prisma)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generar con: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-here-minimum-32-chars"

# ─────────────────────────────────────────────
# OAUTH PROVIDERS
# ─────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─────────────────────────────────────────────
# CACHE — Upstash Redis
# ─────────────────────────────────────────────
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─────────────────────────────────────────────
# BACKGROUND JOBS — Inngest
# ─────────────────────────────────────────────
# https://app.inngest.com/
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# ─────────────────────────────────────────────
# EMAIL — Resend
# ─────────────────────────────────────────────
# https://resend.com/
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@surebettracker.pro"

# ─────────────────────────────────────────────
# SEGURIDAD
# ─────────────────────────────────────────────
# Para HMAC de webhooks outbound — generar con: openssl rand -hex 32
WEBHOOK_SECRET_SALT="your-webhook-secret-salt-hex"
# Para hashear API keys — generar con: openssl rand -hex 32
API_KEY_SALT="your-api-key-salt-hex"

# ─────────────────────────────────────────────
# INTEGRACIONES FUTURAS
# ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# TELEGRAM_WEBHOOK_SECRET="your-telegram-webhook-secret"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_VERSION="0.1.0"
NODE_ENV="development"
