generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ════════════════════════════════════════════
// ENUMS
// ════════════════════════════════════════════

enum UserPlan {
  FREE
  PRO
  PRO_TRACKER
  ENTERPRISE
}

enum BookmakerStatus {
  ACTIVE
  LIMITED
  GUBBED
  CLOSED
  SUSPENDED
}

// Discriminador de tipo de apuesta
enum BetType {
  ARBITRAGE  // surebet — ganancia garantizada
  MIDDLE     // apuesta a la franja media — puede ganar ambas piernas
  SINGLE     // apuesta simple a un evento
  COMBO      // acumuladora / parlay
  CASINO     // sesión de casino / apuesta de casino
  CUSTOM     // operación personalizada sin categoría predefinida
}

// Estado unificado — aplica a BetRecord y también a cada BetLeg individual
enum BetStatus {
  PLACED      // en juego, pendiente de resultado
  WON         // ganada (grossProfit > 0)
  LOST        // perdida (grossProfit < 0)
  VOID        // anulada — stakes devueltos íntegramente
  CASHOUT     // cobro anticipado parcial o total
  PARTIAL_WIN // medio ganado (handicap asiático, EW, etc.) — Fase 3
}

enum MarketType {
  MATCH_RESULT
  DOUBLE_CHANCE
  OVER_UNDER
  BOTH_TEAMS_SCORE
  HANDICAP
  ASIAN_HANDICAP
  CORRECT_SCORE
  OUTRIGHT
  PLAYER_PROP
  MONEYLINE
  SPREAD
  OTHER
}

enum CasinoGameType {
  SLOTS
  ROULETTE
  BLACKJACK
  BACCARAT
  POKER
  LIVE_CASINO
  DICE
  BONUS_BUY
  OTHER
}

enum SportType {
  FOOTBALL
  TENNIS
  BASKETBALL
  BASEBALL
  HOCKEY
  CRICKET
  RUGBY
  GOLF
  MMA
  BOXING
  CYCLING
  MOTORSPORT
  ESPORTS
  OTHER
}

enum TransactionType {
  INITIAL_DEPOSIT
  DEPOSIT
  WITHDRAWAL
  BONUS
  TRANSFER_IN     // dinero recibido desde otro bookmaker
  TRANSFER_OUT    // dinero enviado a otro bookmaker
  BET_PLACED
  BET_RETURN
  BET_VOID_RETURN
  CASHOUT
  MANUAL_ADJUSTMENT
}

enum CreatedVia {
  MANUAL
  TELEGRAM_BOT
  API_KEY
  CSV_IMPORT
}

enum IntegrationType {
  TELEGRAM
  DISCORD
  WEBHOOK_OUTBOUND
  API_ACCESS
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  PAUSED
  REVOKED
  ERROR
}

enum NotificationType {
  BET_SETTLED
  BET_VOID
  ROI_TARGET_REACHED
  BANKROLL_MILESTONE
  DAILY_SUMMARY
  SYSTEM_MESSAGE
  INTEGRATION_ERROR
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ════════════════════════════════════════════
// AUTENTICACIÓN (NextAuth v5)
// ════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?

  plan          UserPlan @default(FREE)
  planExpiresAt DateTime?
  isAdmin       Boolean  @default(false)

  timezone String @default("Europe/Madrid")
  currency String @default("EUR")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Vinculación con FidesBot (Telegram)
  telegramId       String? @unique
  telegramUsername String?

  accounts      Account[]
  sessions      Session[]
  bookmakers    Bookmaker[]
  bankrolls     Bankroll[]
  betRecords    BetRecord[]
  snapshots     DailySnapshot[]
  settings      UserSettings?
  tags          Tag[]
  auditLogs     AuditLog[]
  integrations  UserIntegration[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  notifications Notification[]
  linkTokens    LinkToken[]

  @@index([email])
  @@index([telegramId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ════════════════════════════════════════════
// CONFIGURACIÓN DE USUARIO
// ════════════════════════════════════════════

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultStake    Decimal? @db.Decimal(12, 2)
  roundStakesTo   Int      @default(1)
  primaryCurrency String   @default("EUR")

  emailLoginAlert    Boolean  @default(true)
  emailOnSettle      Boolean  @default(true)
  emailOnRoiTarget   Boolean  @default(false)
  roiTargetPercent   Decimal? @db.Decimal(6, 2)
  emailOnDailyReport Boolean  @default(false)

  dashboardLayout    Json    @default("{}")
  defaultChartPeriod String  @default("30d")
  compactMode        Boolean @default(false)

  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)

  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// ════════════════════════════════════════
// BANKROLLS — Líneas de negocio independientes
// ════════════════════════════════════════

model Bankroll {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  color       String      @default("#6366f1")
  isDefault   Boolean     @default(false)
  isActive    Boolean     @default(true)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bookmakers  Bookmaker[]

  @@index([userId])
  @@map("bankrolls")
}


// ════════════════════════════════════════════
// BOOKMAKER Y GESTIÓN DE CAPITAL
// ════════════════════════════════════════════

model Bookmaker {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  country    String?
  currency   String          @default("EUR")
  color      String?
  logoUrl    String?
  websiteUrl String?
  notes      String?

  bankrollId  String?
  bankroll    Bankroll? @relation(fields: [bankrollId], references: [id])

  status BookmakerStatus @default(ACTIVE)

  // CRÍTICO: NUNCA actualizar directamente.
  // Usar { increment } / { decrement } atómicos para evitar race conditions.
  currentBalance Decimal @db.Decimal(12, 2)

  // Stats denormalizadas — actualizar con { increment } atómico en cada placement/settlement.
  // totalReturn permite calcular yield sin queries adicionales: yield = totalProfit / totalStaked
  totalProfit    Decimal @default(0) @db.Decimal(12, 2)
  totalStaked    Decimal @default(0) @db.Decimal(12, 2)
  totalReturn    Decimal @default(0) @db.Decimal(12, 2)
  operationCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions            BookmakerTransaction[]
  betLegs                 BetLeg[]
  betBookmakerAllocations BetBookmakerAllocation[]
  primaryBetRecords       BetRecord[]              @relation("PrimaryBookmaker")

  @@index([userId])
  @@index([userId, status])
  @@map("bookmakers")
}

// Ledger inmutable — NUNCA borrar ni actualizar registros.
// Fuente de verdad para reconstruir el saldo de cualquier bookmaker en cualquier punto del tiempo.
model BookmakerTransaction {
  id          String    @id @default(cuid())
  bookmakerId String
  bookmaker   Bookmaker @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)

  userId String

  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  balanceBefore Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)

  currency     String   @default("EUR")
  exchangeRate Decimal? @db.Decimal(10, 6)

  notes         String?
  referenceId   String?   // ID del BetRecord relacionado
  referenceType String?   // 'BetRecord' | 'BalanceAdjustment'

  // Vincula pares TRANSFER_OUT ↔ TRANSFER_IN.
  // El TRANSFER_OUT apunta al ID del TRANSFER_IN correspondiente.
  linkedTransactionId String?
  linkedTransaction   BookmakerTransaction?  @relation("LinkedTransfer", fields: [linkedTransactionId], references: [id])
  linkedFrom          BookmakerTransaction[] @relation("LinkedTransfer")

  createdAt DateTime @default(now())

  @@index([bookmakerId])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("bookmaker_transactions")
}

// ════════════════════════════════════════════
// ENTIDAD CENTRAL — REGISTRO DE APUESTA
// ════════════════════════════════════════════

model BetRecord {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   BetType
  status BetStatus @default(PLACED)

  // Metadatos del evento
  title       String?
  isLive      Boolean    @default(false)
  notes       String?
  sport       SportType? // null para casino
  competition String?
  eventName   String?
  eventDate   DateTime?

  // ─── FINANCIERO CORE ──────────────────────────────────────────────────────
  // Todos los campos Decimal(12,2) para precisión monetaria.
  // grossProfit y totalReturn son null hasta que el registro se liquida.
  totalStake      Decimal  @db.Decimal(12, 2)
  potentialReturn Decimal? @db.Decimal(12, 2) // para PLACED: retorno teórico mínimo garantizado
  grossProfit     Decimal? @db.Decimal(12, 2) // null hasta SETTLED; negativo = pérdida neta
  totalReturn     Decimal? @db.Decimal(12, 2) // null hasta SETTLED
  roi             Decimal? @db.Decimal(8, 4)  // null hasta SETTLED; grossProfit / totalStake × 100
  // ─────────────────────────────────────────────────────────────────────────

  datePlaced  DateTime  @default(now())
  dateSettled DateTime?

  createdVia    CreatedVia @default(MANUAL)
  externalRef   String?    // referencia externa (ID de apuesta en el bookmaker, etc.)

  // Integración FidesBot
  isApproximate Boolean @default(false) // datos de la alerta, no confirmados por el usuario
  botPendingId  String? @unique          // ID interno del bot — evita registros duplicados

  deletedAt DateTime? // soft delete — preserva el historial financiero

  // Bookmaker principal para operaciones de una sola casa (SINGLE, COMBO, CASINO, CUSTOM).
  // Para ARBITRAGE y MIDDLE, este campo es null — las casas están en BetLeg.
  primaryBookmakerId String?
  primaryBookmaker   Bookmaker? @relation("PrimaryBookmaker", fields: [primaryBookmakerId], references: [id])

  // Satélites de tipo — máximo uno activo según el valor de `type`
  arbitrageDetail ArbitrageDetail?
  middleDetail    MiddleDetail?
  singleBetDetail SingleBetDetail?
  comboDetail     ComboDetail?
  casinoDetail    CasinoDetail?
  customDetail    CustomDetail?

  // Piernas multi-bookmaker (solo ARBITRAGE y MIDDLE)
  legs BetLeg[]

  // Analytics de allocations por bookmaker (todos los tipos)
  allocations BetBookmakerAllocation[]

  tags BetRecordTag[]

  @@index([userId])
  @@index([userId, type])
  @@index([userId, status])
  @@index([userId, datePlaced])
  @@index([userId, dateSettled])
  @@index([userId, type, status])
  @@index([userId, sport])
  @@index([userId, deletedAt])
  @@map("bet_records")
}

// Tabla de piernas compartida por ARBITRAGE y MIDDLE.
// Cada pierna representa una apuesta individual en un bookmaker específico.
model BetLeg {
  id          String    @id @default(cuid())
  betRecordId String
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)
  bookmakerId String
  bookmaker   Bookmaker @relation(fields: [bookmakerId], references: [id])

  selection       String
  odds            Decimal  @db.Decimal(8, 4)
  stake           Decimal  @db.Decimal(12, 2)
  potentialReturn Decimal  @db.Decimal(12, 2) // stake × odds — almacenado, nunca recalculado
  currency        String   @default("EUR")

  status        BetStatus @default(PLACED)
  cashoutAmount Decimal?  @db.Decimal(12, 2)

  deletedAt DateTime? // soft delete para historial

  @@index([betRecordId])
  @@index([bookmakerId])
  @@map("bet_legs")
}

// ════════════════════════════════════════════
// SATÉLITES DE TIPO (1:1 opcional con BetRecord)
// ════════════════════════════════════════════

// Para BetType.ARBITRAGE
model ArbitrageDetail {
  id          String    @id @default(cuid())
  betRecordId String    @unique
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)

  arbPercentage  Decimal @db.Decimal(8, 4) // % de ventaja del arbitraje
  expectedReturn Decimal @db.Decimal(12, 2) // retorno garantizado mínimo

  winningLegId String? // ID de la pierna ganadora — se rellena en settlement

  @@map("arbitrage_details")
}

// Para BetType.MIDDLE
// Un middle es una apuesta en dos lados de un spread/total donde
// el resultado puede "caer en el medio" y ganar ambas piernas.
model MiddleDetail {
  id          String    @id @default(cuid())
  betRecordId String    @unique
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)

  // Descripción textual de la franja ganadora.
  // Ej: "Lakers win by exactly 4 points" o "3.5–4.5 goals"
  middleRange    String
  worstCaseLoss  Decimal @db.Decimal(12, 2) // pérdida si el middle no entra (negativo)
  bestCaseProfit Decimal @db.Decimal(12, 2) // ganancia si el middle entra (positivo)

  // Se rellena en settlement
  middleHit    Boolean? // true = ambas piernas ganaron
  winningLegId String?  // null si middleHit = true (ambas ganan)

  @@map("middle_details")
}

// Para BetType.SINGLE
model SingleBetDetail {
  id          String    @id @default(cuid())
  betRecordId String    @unique
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)

  selection    String
  odds         Decimal    @db.Decimal(8, 4)
  marketType   MarketType @default(MATCH_RESULT)
  isFreeBet    Boolean    @default(false)
  freeBetValue Decimal?   @db.Decimal(12, 2) // valor de la apuesta gratis si aplica

  @@map("single_bet_details")
}

// Para BetType.COMBO
model ComboDetail {
  id          String    @id @default(cuid())
  betRecordId String    @unique
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)

  totalOdds Decimal @db.Decimal(10, 4) // producto de todas las cuotas
  legCount  Int
  comboType String  @default("ACCUMULATOR") // TRIXIE, YANKEE, LUCKY15, etc.
  eachWay   Boolean @default(false)

  selections ComboSelection[]

  @@map("combo_details")
}

// Cada selección individual dentro de un COMBO
model ComboSelection {
  id            String      @id @default(cuid())
  comboDetailId String
  comboDetail   ComboDetail @relation(fields: [comboDetailId], references: [id], onDelete: Cascade)

  eventName String
  selection String
  odds      Decimal    @db.Decimal(8, 4)
  sport     SportType?
  result    BetStatus  @default(PLACED) // resultado de ESTA selección individual

  @@index([comboDetailId])
  @@map("combo_selections")
}

// Para BetType.CASINO
model CasinoDetail {
  id          String    @id @default(cuid())
  betRecordId String    @unique
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)

  gameType        CasinoGameType
  gameName        String?         // "Lightning Roulette", "Book of Dead", etc.
  sessionDuration Int?            // duración de la sesión en minutos
  initialBalance  Decimal?        @db.Decimal(12, 2) // saldo al inicio de la sesión
  finalBalance    Decimal?        @db.Decimal(12, 2) // saldo al final de la sesión
  avgBetSize      Decimal?        @db.Decimal(12, 2) // tamaño medio de cada apuesta individual
  numberOfBets    Int?            // número total de apuestas dentro de la sesión
  bonusUsed       Boolean         @default(false)
  bonusAmount     Decimal?        @db.Decimal(12, 2)

  @@map("casino_details")
}

// Para BetType.CUSTOM
model CustomDetail {
  id          String    @id @default(cuid())
  betRecordId String    @unique
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)

  category String? // etiqueta libre definida por el usuario
  metadata Json    @default("{}") // cualquier dato adicional en formato JSON

  @@map("custom_details")
}

// ════════════════════════════════════════════
// ANALYTICS — ALLOCATIONS POR BOOKMAKER
// ════════════════════════════════════════════

// Permite queries O(1) "¿cuánto gané/perdí en este bookmaker?" sin JOINs complejos.
// Se crea/actualiza en la misma transacción que BetRecord.
// Cubre todos los tipos: SINGLE (1 allocation), ARBITRAGE/MIDDLE (N allocations = N piernas).
model BetBookmakerAllocation {
  id          String    @id @default(cuid())
  betRecordId String
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)
  bookmakerId String
  bookmaker   Bookmaker @relation(fields: [bookmakerId], references: [id])

  stakeAllocated  Decimal  @db.Decimal(12, 2)
  returnAllocated Decimal? @db.Decimal(12, 2) // null hasta settlement
  profitAllocated Decimal? @db.Decimal(12, 2) // null hasta settlement; puede ser negativo

  @@unique([betRecordId, bookmakerId])
  @@index([bookmakerId])
  @@index([betRecordId])
  @@map("bet_bookmaker_allocations")
}

// ════════════════════════════════════════════
// TAGS
// ════════════════════════════════════════════

model Tag {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  color String @default("#6366f1")

  betRecords BetRecordTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model BetRecordTag {
  betRecordId String
  betRecord   BetRecord @relation(fields: [betRecordId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([betRecordId, tagId])
  @@map("bet_record_tags")
}

// ════════════════════════════════════════════
// ANALYTICS — SNAPSHOTS DIARIOS PRE-COMPUTADOS
// ════════════════════════════════════════════

// Se calcula de forma incremental en cada placement/settlement.
// Para usuarios con >1k registros, es la fuente de verdad para métricas del dashboard.
model DailySnapshot {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date

  // Estado del bankroll a cierre del día
  totalEffectiveBalance Decimal @db.Decimal(12, 2)
  totalAvailableBalance Decimal @db.Decimal(12, 2)
  totalInPlay           Decimal @db.Decimal(12, 2)

  // Flujos de capital ese día
  dailyDeposited Decimal @db.Decimal(12, 2)
  dailyWithdrawn Decimal @db.Decimal(12, 2)

  // P&L global del día (todos los tipos combinados)
  dailyProfit     Decimal @db.Decimal(12, 2)
  dailyStaked     Decimal @db.Decimal(12, 2)
  dailyReturn     Decimal @db.Decimal(12, 2)
  dailyOperations Int

  // Acumulados desde el inicio del usuario
  cumulativeProfit     Decimal @db.Decimal(12, 2)
  cumulativeStaked     Decimal @db.Decimal(12, 2)
  cumulativeDeposited  Decimal @db.Decimal(12, 2)
  cumulativeWithdrawn  Decimal @db.Decimal(12, 2)
  cumulativeOperations Int

  createdAt DateTime @default(now())

  byType DailySnapshotByType[]

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_snapshots")
}

// Desglose del DailySnapshot por tipo de apuesta.
// Permite analytics independientes por tipo sin recalcular desde BetRecord.
model DailySnapshotByType {
  id         String        @id @default(cuid())
  snapshotId String
  snapshot   DailySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  type       BetType

  dailyProfit     Decimal @db.Decimal(12, 2)
  dailyStaked     Decimal @db.Decimal(12, 2)
  dailyReturn     Decimal @db.Decimal(12, 2)
  dailyOperations Int

  @@unique([snapshotId, type])
  @@index([snapshotId])
  @@map("daily_snapshot_by_type")
}

// ════════════════════════════════════════════
// AUDITORÍA — NUNCA BORRAR
// ════════════════════════════════════════════

model AuditLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action     String
  entityType String
  entityId   String

  before Json?
  after  Json?

  ipAddress    String?
  userAgent    String?
  isAnonymized Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ════════════════════════════════════════════
// VINCULACIÓN FIDESBOT — TOKENS DE UN USO
// ════════════════════════════════════════════

// Token temporal para el flujo de vinculación Telegram ↔ DualStats.
// Se genera en la web, expira en 10 min, uso único.
// El usuario lo consume pulsando el deep link en FidesBot.
model LinkToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String    @unique           // 32 bytes hex (64 chars) — generado con randomBytes
  expiresAt DateTime                    // createdAt + 10 min
  usedAt    DateTime?                   // null = no usado; non-null = ya vinculado

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("link_tokens")
}

// ════════════════════════════════════════════
// INTEGRACIONES EXTERNAS
// ════════════════════════════════════════════

model UserIntegration {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   IntegrationType
  status IntegrationStatus @default(PENDING)

  externalId String?
  name       String?
  config     Json      @default("{}")

  lastUsedAt DateTime?
  lastError  String?
  errorCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("user_integrations")
}

model ApiKey {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  keyHash     String  @unique
  keyPrefix   String
  permissions Json    @default("[\"records:read\"]")

  lastUsedAt DateTime?
  lastUsedIp String?
  expiresAt  DateTime?
  isRevoked  Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model Webhook {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  url        String
  secretHash String
  events     String[]

  isActive     Boolean @default(true)
  failureCount Int     @default(0)

  lastCalledAt DateTime?
  lastStatus   Int?
  lastError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("webhooks")
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  NotificationType
  title String
  body  String
  data  Json?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

